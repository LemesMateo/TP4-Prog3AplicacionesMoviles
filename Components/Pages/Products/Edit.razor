@page "/products/edit/{Id:int}"
@inject IProductService ProductService
@inject ICategoryService CategoryService
@inject NavigationManager Navigation

<PageTitle>Editar producto</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Editar producto</h1>
    <a class="btn btn-secondary" href="products">← Cancelar</a>
</div>

<p class="text-muted">
    Envía un <code>PUT https://fakestoreapi.com/products/{Id}</code> con los datos del formulario.
</p>

@if (loading)
{
    <p><em>Cargando producto...</em></p>
}
else if (loadError is not null)
{
    <div class="alert alert-danger" role="alert">@loadError</div>
}
else
{
    @if (error is not null)
    {
        <div class="alert alert-danger" role="alert">@error</div>
    }

    <EditForm Model="model" OnValidSubmit="SubmitAsync" class="card shadow-sm p-4">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label">Título</label>
            <InputText class="form-control" @bind-Value="model.Title" />
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="form-label">Precio</label>
                <InputNumber class="form-control" @bind-Value="model.Price" />
            </div>
            <div class="col-md-8 mb-3">
                <label class="form-label">Categoría</label>
                @if (categories.Count == 0)
                {
                    <InputText class="form-control" @bind-Value="model.Category" />
                }
                else
                {
                    <InputSelect class="form-select" @bind-Value="model.Category">
                        @foreach (var c in categories)
                        {
                            <option value="@c">@c</option>
                        }
                    </InputSelect>
                }
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">URL de imagen</label>
            <InputText class="form-control" @bind-Value="model.Image" />
        </div>

        <div class="mb-3">
            <label class="form-label">Descripción</label>
            <InputTextArea class="form-control" rows="4" @bind-Value="model.Description" />
        </div>

        <button type="submit" class="btn btn-warning" disabled="@submitting">
            @if (submitting)
            {
                <span>Guardando...</span>
            }
            else
            {
                <span><span class="bi bi-save" aria-hidden="true"></span> Guardar cambios</span>
            }
        </button>
    </EditForm>
}

@code {
    [Parameter] public int Id { get; set; }

    private Product model = new();
    private List<string> categories = new();
    private bool loading = true;
    private bool submitting;
    private string? loadError;
    private string? error;

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        loadError = null;
        try
        {
            model = await ProductService.GetByIdAsync(Id);
            try { categories = await CategoryService.GetAllAsync(); }
            catch { categories = new List<string>(); }
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private async Task SubmitAsync()
    {
        submitting = true;
        error = null;
        try
        {
            await ProductService.UpdateAsync(Id, model);
            Navigation.NavigateTo("products");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            submitting = false;
        }
    }
}
