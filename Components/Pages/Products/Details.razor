@page "/products/details/{Id:int}"
@inject IProductService ProductService
@inject NavigationManager Navigation

<PageTitle>Detalle de producto</PageTitle>

@if (loading)
{
    <p><em>Cargando producto...</em></p>
}
else if (error is not null)
{
    <div class="alert alert-danger" role="alert">@error</div>
    <a class="btn btn-secondary" href="products">← Volver al listado</a>
}
else if (product is null)
{
    <div class="alert alert-warning" role="alert">Producto no encontrado.</div>
    <a class="btn btn-secondary" href="products">← Volver al listado</a>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0">@product.Title</h1>
        <a class="btn btn-secondary" href="products">← Volver al listado</a>
    </div>

    <div class="card shadow-sm">
        <div class="row g-0">
            <div class="col-md-4 d-flex align-items-center justify-content-center p-4 bg-light">
                <img src="@product.Image" alt="@product.Title"
                     style="max-width: 100%; max-height: 320px; object-fit: contain;" />
            </div>
            <div class="col-md-8">
                <div class="card-body">
                    <h5 class="card-title">@product.Title</h5>
                    <p class="card-text">
                        <span class="badge bg-secondary">@product.Category</span>
                    </p>
                    <h3 class="text-success">$@product.Price.ToString("0.00")</h3>
                    <p class="card-text">@product.Description</p>
                    <ul class="list-unstyled text-muted small">
                        <li><strong>ID:</strong> @product.Id</li>
                        <li><strong>Endpoint:</strong> <code>GET /products/@product.Id</code></li>
                    </ul>
                    <a class="btn btn-warning" href="@($"products/edit/{product.Id}")">
                        <span class="bi bi-pencil" aria-hidden="true"></span> Editar
                    </a>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private Product? product;
    private bool loading = true;
    private string? error;

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        error = null;
        product = null;
        try
        {
            product = await ProductService.GetByIdAsync(Id);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }
}
